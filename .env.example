# Qiita アクセストークン（アカウントごと）
# 発行手順:
#   1. 対象のQiitaアカウントにブラウザでログインする
#   2. 以下のURLにアクセスしてトークンを発行する（read_qiita / write_qiita にチェック）
#      https://qiita.com/settings/tokens/new?read_qiita=1&write_qiita=1&description=qiita-cli
#   3. 発行されたトークンを下記の対応する行に貼り付ける
#
# トークンはこのファイル（.env）にのみ保存し、会話や他のファイルに書き出さないこと。

# Account-A: すもも🍑 https://qiita.com/prum_hitomi
QIITA_TOKEN_ACCOUNT_A=your_qiita_token_here

# Account-B: ぷらむん https://qiita.com/prumnn
QIITA_TOKEN_ACCOUNT_B=your_qiita_token_here

# Account-C: ひとみん（暫定） https://qiita.com/hitomin_poke
QIITA_TOKEN_ACCOUNT_C=your_qiita_token_here
